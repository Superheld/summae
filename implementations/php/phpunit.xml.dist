<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         failOnWarning="true"
         failOnRisky="true"
         cacheDirectory=".phpunit.cache">
    <testsuites>
        <testsuite name="core">
            <directory>packages/core/tests</directory>
        </testsuite>
        <testsuite name="laravel">
            <directory>packages/laravel/tests</directory>
        </testsuite>
        <testsuite name="cli">
            <directory>packages/cli/tests</directory>
        </testsuite>
        <testsuite name="runner">
            <directory>runner/tests</directory>
        </testsuite>
    </testsuites>
    <!-- Coverage-Gate misst den Fachkern (packages/core/src). Adapter (laravel-DB) und
         cli sind integrations-/cross-getestet, nicht unit — daher nicht im Coverage-Floor. -->
    <source>
        <include>
            <directory>packages/core/src</directory>
        </include>
    </source>
</phpunit>
