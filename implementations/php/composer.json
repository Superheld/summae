{
    "name": "superheld/summae-php",
    "description": "PHP-Referenzimplementierung Rechnungswesen — Monorepo (core, laravel, cli)",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "superheld/summae-cli": "@dev",
        "superheld/summae-core": "@dev",
        "superheld/summae-laravel": "@dev"
    },
    "require-dev": {
        "opis/json-schema": "^2.6",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload-dev": {
        "psr-4": {
            "Summae\\Core\\Tests\\": "packages/core/tests/",
            "Summae\\Laravel\\Tests\\": "packages/laravel/tests/",
            "Summae\\Cli\\Tests\\": "packages/cli/tests/",
            "Summae\\Runner\\": "runner/src/",
            "Summae\\Runner\\Tests\\": "runner/tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
