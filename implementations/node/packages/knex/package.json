{
  "name": "@superheld/summae-knex",
  "version": "0.1.0",
  "description": "Datenbank-Adapter (Node) für @superheld/summae-core — persistiert in das geteilte summae_*-Schema via Knex (Query-/Schema-Builder) + better-sqlite3 / pg",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "accounting",
    "rechnungswesen",
    "summae",
    "knex",
    "sqlite",
    "persistence"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/superheld/summae.git",
    "directory": "implementations/node/packages/knex"
  },
  "homepage": "https://github.com/superheld/summae/tree/main/implementations/node/packages/knex#readme",
  "bugs": "https://github.com/superheld/summae/issues",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "@superheld/summae-core": "workspace:*",
    "better-sqlite3": "^12.2.0",
    "knex": "^3.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.9.3",
    "tsup": "^8.5.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  }
}
