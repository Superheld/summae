{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://netmechanics.de/rechnungswesen/format/0.6/format.schema.json",
  "title": "Rechnungswesen-Datenformat v0.6",
  "$defs": {
    "uuid": { "type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "money": {
      "type": "object",
      "required": ["amount", "currency"],
      "properties": {
        "amount": { "type": "string", "pattern": "^-?\\d+(\\.\\d{1,4})?$" },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
      },
      "additionalProperties": false
    },
    "dimensionValue": {
      "type": "object",
      "required": ["type", "code"],
      "properties": { "type": { "type": "string" }, "code": { "type": "string" } },
      "additionalProperties": false
    },
    "taxTag": {
      "type": "object",
      "required": ["code", "appliedVersion"],
      "properties": {
        "code": { "type": "string" },
        "appliedVersion": { "$ref": "#/$defs/date" },
        "reportingKey": { "type": "string" },
        "baseMoney": { "$ref": "#/$defs/money" }
      },
      "additionalProperties": false
    },
    "entryLine": {
      "type": "object",
      "required": ["accountId", "side", "money"],
      "properties": {
        "accountId": { "$ref": "#/$defs/uuid" },
        "side": { "enum": ["debit", "credit"] },
        "money": { "$ref": "#/$defs/money" },
        "dimensions": { "type": "array", "items": { "$ref": "#/$defs/dimensionValue" } },
        "taxTag": { "anyOf": [ { "$ref": "#/$defs/taxTag" }, { "type": "null" } ] }
      },
      "additionalProperties": false
    },
    "journalEntry": {
      "type": "object",
      "required": ["id", "sequenceNumber", "status", "entryDate", "voucherDate", "recordedAt", "periodRef", "voucherId", "lines"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "sequenceNumber": { "type": "integer", "minimum": 1 },
        "status": { "enum": ["entered", "finalized"] },
        "entryDate": { "$ref": "#/$defs/date" },
        "voucherDate": { "$ref": "#/$defs/date" },
        "recordedAt": { "$ref": "#/$defs/timestamp" },
        "periodRef": {
          "type": "object",
          "required": ["fiscalYear", "period"],
          "properties": { "fiscalYear": { "type": "integer" }, "period": { "type": "integer", "minimum": 1 } },
          "additionalProperties": false
        },
        "voucherId": { "$ref": "#/$defs/uuid" },
        "text": { "type": "string" },
        "lines": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/entryLine" } },
        "reverses": { "anyOf": [ { "$ref": "#/$defs/uuid" }, { "type": "null" } ] },
        "reversedBy": { "anyOf": [ { "$ref": "#/$defs/uuid" }, { "type": "null" } ] },
        "settles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["openItemId", "money"],
            "properties": { "openItemId": { "$ref": "#/$defs/uuid" }, "money": { "$ref": "#/$defs/money" } },
            "additionalProperties": false
          }
        },
        "previousEntryHash": { "type": "string", "description": "reserviert, in v0.2 nicht belegt" }
      },
      "additionalProperties": false
    },
    "account": {
      "type": "object",
      "required": ["id", "number", "name", "type", "status"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "number": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "type": { "enum": ["asset", "liability", "equity", "expense", "revenue"] },
        "subtype": { "type": "string" },
        "status": { "enum": ["active", "locked"] },
        "validFrom": { "$ref": "#/$defs/date" },
        "validTo": { "anyOf": [ { "$ref": "#/$defs/date" }, { "type": "null" } ] },
        "mappings": { "type": "object" }
      },
      "additionalProperties": false
    },
    "voucher": {
      "type": "object",
      "required": ["id", "voucherNumber", "voucherDate"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "voucherNumber": { "type": "string" },
        "voucherDate": { "$ref": "#/$defs/date" },
        "issuer": { "type": "string" },
        "totalMoney": { "$ref": "#/$defs/money" },
        "documents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["uri", "sha256"],
            "properties": { "uri": { "type": "string" }, "sha256": { "type": "string" }, "mimeType": { "type": "string" } },
            "additionalProperties": false
          }
        },
        "due": { "$ref": "#/$defs/date" },
        "recurring": { "type": "boolean" },
        "economicYear": { "type": "integer" },
        "supplierTaxationMethod": { "enum": ["accrual", "cash"] },
        "serviceDate": { "$ref": "#/$defs/date" },
        "servicePeriod": {
          "type": "object",
          "required": ["from", "to"],
          "properties": { "from": { "$ref": "#/$defs/date" }, "to": { "$ref": "#/$defs/date" } },
          "additionalProperties": false
        },
        "partnerId": { "$ref": "#/$defs/uuid" },
        "kind": { "enum": ["invoice_out", "invoice_in", "credit_note_out", "credit_note_in", "payment", "payroll", "internal", "opening"] }
      },
      "additionalProperties": false
    },
    "partner": {
      "type": "object",
      "required": ["id", "name", "kind"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "name": { "type": "string" },
        "kind": { "enum": ["customer", "supplier", "both"] },
        "vatId": { "type": "string" },
        "address": { "type": "object" },
        "paymentTermsDays": { "type": "integer", "minimum": 0 },
        "accountIds": { "type": "array", "items": { "$ref": "#/$defs/uuid" } }
      },
      "additionalProperties": false
    },
    "openItem": {
      "type": "object",
      "required": ["id", "kind", "originEntryId", "originLineIndex", "money"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "kind": { "enum": ["receivable", "payable"] },
        "originEntryId": { "$ref": "#/$defs/uuid" },
        "originLineIndex": { "type": "integer", "minimum": 0 },
        "partnerId": { "$ref": "#/$defs/uuid" },
        "money": { "$ref": "#/$defs/money" },
        "settlements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["entryId", "money", "settledAt"],
            "properties": { "entryId": { "$ref": "#/$defs/uuid" }, "money": { "$ref": "#/$defs/money" }, "settledAt": { "$ref": "#/$defs/date" } },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "profile": {
      "type": "object",
      "required": ["id", "name", "version", "chartOfAccounts", "taxCodes", "defaults"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": "string" },
        "chartOfAccounts": { "type": "string" },
        "taxCodes": { "type": "array", "items": { "type": "string" } },
        "mappings": { "type": "array", "items": { "type": "string" } },
        "defaults": { "type": "object" },
        "packPolicy": { "$ref": "#/$defs/packPolicy" }
      },
      "additionalProperties": false
    },
    "packPolicy": {
      "type": "object",
      "properties": {
        "roundingMode": { "enum": ["halfUpAwayFromZero", "halfEven"] },
        "taxRoundingGranularity": { "enum": ["perVoucher", "perLine"] },
        "currencyScale": { "type": "integer", "minimum": 0, "maximum": 4 }
      },
      "additionalProperties": false,
      "description": "Pack-Policy-Parameter (v0.6); fehlend = DE-Default {halfUpAwayFromZero, perVoucher, 2}"
    },
    "module": {
      "type": "object",
      "required": ["formatVersion", "id", "kind", "version", "contributes", "data"],
      "properties": {
        "formatVersion": { "type": "string" },
        "id": { "type": "string" },
        "kind": { "enum": ["accounts", "tax", "mapping", "depreciation", "policy", "assetAccounts"] },
        "version": { "type": "string" },
        "name": { "type": "string" },
        "contributes": {
          "type": "array",
          "items": { "enum": ["accounts", "taxCodes", "mappings", "assetAccounts", "policy", "depreciation"] }
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "id"],
            "properties": {
              "kind": { "type": "string" },
              "id": { "type": "string" },
              "version": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "data": { "type": "object" }
      },
      "additionalProperties": false,
      "description": "kleinste adressierbare Pack-Einheit (v0.6); data ist kind-abhängig (discriminated union per kind, hier offen gehalten, weil je kind verschieden)"
    },
    "packManifest": {
      "type": "object",
      "required": ["formatVersion", "id", "version", "modules", "packPolicy"],
      "properties": {
        "formatVersion": { "type": "string" },
        "id": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": "string" },
        "modules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "id"],
            "properties": {
              "kind": { "type": "string" },
              "id": { "type": "string" },
              "version": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "overrides": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["op", "ref"],
            "properties": {
              "op": { "enum": ["remove", "replace"] },
              "ref": {
                "type": "object",
                "required": ["kind", "id"],
                "properties": {
                  "kind": { "type": "string" },
                  "id": { "type": "string" },
                  "version": { "type": "string" }
                },
                "additionalProperties": false
              },
              "with": {
                "type": "object",
                "required": ["kind", "id"],
                "properties": {
                  "kind": { "type": "string" },
                  "id": { "type": "string" },
                  "version": { "type": "string" }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "taxCodes": { "type": "array", "items": { "type": "string" } },
        "defaults": {
          "type": "object",
          "properties": {
            "taxationMethod": { "enum": ["accrual", "cash"] },
            "smallBusiness": {},
            "vatPeriod": { "enum": ["monthly", "quarterly"] }
          },
          "additionalProperties": false
        },
        "packPolicy": { "$ref": "#/$defs/packPolicy" }
      },
      "additionalProperties": false,
      "description": "benanntes, kuratiertes Modul-Bündel (v0.6); packPolicy ist Pflicht-Kopie (E-A)"
    },
    "mapping": {
      "type": "object",
      "required": ["id", "kind", "version", "positions"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "enum": ["balance-sheet", "income-statement", "cash-basis-categories"] },
        "version": { "type": "string" },
        "positions": { "type": "array", "items": { "$ref": "#/$defs/mappingPosition" } }
      },
      "additionalProperties": false
    },
    "mappingPosition": {
      "type": "object",
      "required": ["key", "label"],
      "properties": {
        "key": { "type": "string" },
        "label": { "type": "string" },
        "side": { "enum": ["assets", "liabilitiesAndEquity"], "description": "nur am Wurzelknoten einer balance-sheet-Mapping; bestimmt Aktiv-/Passivseite (v0.5/F-007)" },
        "includesNetIncome": { "type": "boolean" },
        "accounts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "from": { "type": "string" }, "to": { "type": "string" },
              "numbers": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "children": { "type": "array", "items": { "$ref": "#/$defs/mappingPosition" } }
      },
      "additionalProperties": false
    },
    "auditRecord": {
      "type": "object",
      "required": ["id", "at", "actor", "objectType", "objectId", "action", "changes"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "at": { "$ref": "#/$defs/timestamp" },
        "actor": { "type": "string" },
        "objectType": { "type": "string" },
        "objectId": { "$ref": "#/$defs/uuid" },
        "action": { "type": "string" },
        "changes": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": { "from": {}, "to": {} },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "manifest": {
      "type": "object",
      "required": ["formatVersion", "tenantId", "tenantName", "baseCurrency", "exportedAt", "streams", "hashAlgorithm", "contentHashes"],
      "properties": {
        "formatVersion": { "type": "string" },
        "tenantId": { "$ref": "#/$defs/uuid" },
        "tenantName": { "type": "string" },
        "baseCurrency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "exportedAt": { "$ref": "#/$defs/timestamp" },
        "streams": { "type": "array", "items": { "type": "string" }, "description": "enthaltene Objektströme; auditLog ist immer dabei (v0.5/F-005)" },
        "hashAlgorithm": { "type": "string", "const": "sha256" },
        "contentHashes": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
