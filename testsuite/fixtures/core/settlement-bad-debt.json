{
  "fixture": "settlement-bad-debt",
  "description": "Forderungsausfall (§ 17 UStG): Ausbuchung als sichtbare Buchung mit USt-Korrektur, OP per difference kind=bad_debt geschlossen, VA neutralisiert.",
  "covers": ["F-CORE-019", "F-TAX-008"],
  "setup": {
    "tenant": { "name": "Fixture GmbH", "baseCurrency": "EUR" },
    "accounts": [
      { "number": "1400", "name": "Forderungen", "type": "asset", "subtype": "ar" },
      { "number": "8400", "name": "Erlöse 19%", "type": "revenue" },
      { "number": "6936", "name": "Forderungsverluste", "type": "expense" },
      { "number": "1776", "name": "USt 19%", "type": "liability", "subtype": "tax_out" }
    ],
    "fiscalYears": [ { "year": 2026, "start": "2026-01-01", "end": "2026-12-31" } ],
    "vouchers": [
      { "id": "$V1", "voucherNumber": "AR-400", "voucherDate": "2026-01-15" },
      { "id": "$V2", "voucherNumber": "INSOLVENZ-400", "voucherDate": "2026-03-20" }
    ],
    "taxCodes": [
      { "code": "USt19", "versions": [ { "validFrom": "2024-01-01", "validTo": null, "rate": "19.00", "taxAccount": "1776", "reportingKey": "81" } ] }
    ]
  },
  "steps": [
    {
      "op": "post",
      "input": {
        "entryDate": "2026-01-15", "voucherId": "$V1", "text": "Ausgangsrechnung",
        "lines": [
          { "account": "1400", "side": "debit", "money": { "amount": "1190.00", "currency": "EUR" } },
          { "account": "8400", "side": "credit", "money": { "amount": "1000.00", "currency": "EUR" },
            "taxTag": { "code": "USt19", "appliedVersion": "2024-01-01", "reportingKey": "81", "baseMoney": { "amount": "1000.00", "currency": "EUR" } } },
          { "account": "1776", "side": "credit", "money": { "amount": "190.00", "currency": "EUR" },
            "taxTag": { "code": "USt19", "appliedVersion": "2024-01-01", "reportingKey": "81", "baseMoney": { "amount": "1000.00", "currency": "EUR" } } }
        ]
      },
      "expect": { "result": { "sequenceNumber": 1, "openItemsCreated": [ { "id": "$OP1" } ] } }
    },
    {
      "op": "post",
      "input": {
        "entryDate": "2026-03-20", "voucherId": "$V2", "text": "Forderungsausfall (Insolvenz, uneinbringlich)",
        "lines": [
          { "account": "6936", "side": "debit", "money": { "amount": "1000.00", "currency": "EUR" } },
          { "account": "1776", "side": "debit", "money": { "amount": "190.00", "currency": "EUR" },
            "taxTag": { "code": "USt19", "appliedVersion": "2024-01-01", "reportingKey": "81", "baseMoney": { "amount": "-1000.00", "currency": "EUR" } } },
          { "account": "1400", "side": "credit", "money": { "amount": "1190.00", "currency": "EUR" } }
        ]
      },
      "expect": { "result": { "sequenceNumber": 2, "id": "$E2" } }
    },
    {
      "op": "settle",
      "input": { "entryId": "$E2", "allocations": [ { "openItemId": "$OP1", "money": { "amount": "1190.00", "currency": "EUR" }, "difference": { "money": { "amount": "1190.00", "currency": "EUR" }, "kind": "bad_debt" } } ] },
      "expect": { "result": { "openItems": [ { "id": "$OP1", "remaining": { "amount": "0.00", "currency": "EUR" }, "status": "settled" } ] } }
    }
  ],
  "projections": [
    {
      "name": "vatReturn",
      "params": { "year": 2026, "quarter": 1, "asOf": "2026-07-01" },
      "expect": {
        "comment": "Rechnung und Ausfall in Q1: Bemessungsgrundlage und Steuer neutralisiert",
        "keys": { "81": { "base": "0.00", "tax": "0.00" } },
        "payload": { "amount": "0.00", "currency": "EUR" }
      }
    }
  ]
}
