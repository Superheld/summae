{
  "fixture": "de-pack-resolves",
  "description": "DE-Pack-Skeleton: das ausgelieferte `de`-Pack wird aus der Pack-Bibliothek geladen (kein Inline) — neutraler Rahmen (32) + de-extras (8) = 40 Konten, USt-Steuercodes, DE-Policy (cash/perVoucher). Beweist Auflösung + Mandantenbau + eine Standard-USt-Ausgangsbuchung (SF-02) auf den eigenen, neutralen DE-Nummern (4000 Erlöse, 3100 USt — NICHT SKR).",
  "covers": ["F-PACK-011", "SF-02"],
  "setup": {},
  "steps": [
    {
      "op": "resolvePack",
      "input": { "manifest": "de", "version": "2026.1" },
      "expect": {
        "result": {
          "id": "de",
          "version": "2026.1",
          "accountCount": 40,
          "assetAccounts": { "default": { "acquisitionCounterAccount": "1200", "depreciationExpenseAccount": "6500", "gwgExpenseAccount": "6510", "disposalProceedsAccount": "4900", "disposalLossAccount": "6900" } },
          "packPolicy": { "roundingMode": "halfUpAwayFromZero", "taxRoundingGranularity": "perVoucher", "currencyScale": 2 }
        }
      }
    },
    {
      "op": "createTenant",
      "input": { "name": "Mustermann GmbH", "baseCurrency": "EUR", "pack": "de", "firstFiscalYear": 2026 },
      "expect": { "result": { "id": "$T1", "pack": { "id": "de", "version": "2026.1" }, "accountCount": 40, "taxationMethod": "cash" } }
    },
    {
      "op": "postVoucher",
      "input": {
        "tenant": "$T1",
        "voucher": { "voucherNumber": "AR-001", "voucherDate": "2026-02-10" },
        "entryDate": "2026-02-10", "text": "Beratung Februar",
        "taxCode": "USt19", "direction": "output",
        "netLines": [ { "account": "4000", "money": { "amount": "1000.00", "currency": "EUR" } } ],
        "counterAccount": "1200"
      },
      "expect": { "result": { "grossTotal": { "amount": "1190.00", "currency": "EUR" } } }
    }
  ],
  "projections": [
    {
      "name": "trialBalance",
      "params": { "fiscalYear": 2026, "throughPeriod": 12 },
      "expect": {
        "rows": [
          { "account": "1200", "balance": "1190.00" },
          { "account": "3100", "balance": "-190.00" },
          { "account": "4000", "balance": "-1000.00" }
        ]
      }
    }
  ]
}
