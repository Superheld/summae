{
  "fixture": "us-balance-income",
  "description": "US-Pack: Classified Balance Sheet + Multi-Step Income Statement as projections over the shipped US-GAAP mappings (us-gaap-balance-sheet, us-gaap-income-statement) on the own US numbers. Sale 1,070 (SALETAX 7%) + SG&A 300; net income 700 closes the balance sheet, assets 770 = liabilities and equity 770.",
  "covers": ["F-CORE-015", "SF-10"],
  "setup": {},
  "steps": [
    { "op": "createTenant", "input": { "name": "Balance Corp", "baseCurrency": "USD", "pack": "us", "firstFiscalYear": 2026 },
      "expect": { "result": { "id": "$T1", "pack": { "id": "us", "version": "2026.1" } } } },
    { "op": "postVoucher",
      "input": {
        "tenant": "$T1",
        "voucher": { "voucherNumber": "INV-001", "voucherDate": "2026-03-01" },
        "entryDate": "2026-03-01", "text": "Cash sale",
        "taxCode": "SALETAX", "direction": "output",
        "netLines": [ { "account": "4000", "money": { "amount": "1000.00", "currency": "USD" } } ],
        "counterAccount": "1200"
      },
      "expect": { "result": { "grossTotal": { "amount": "1070.00", "currency": "USD" } } } },
    { "op": "postVoucher",
      "input": {
        "tenant": "$T1",
        "voucher": { "voucherNumber": "EXP-001", "voucherDate": "2026-03-15" },
        "entryDate": "2026-03-15", "text": "Office supplies",
        "lines": [
          { "account": "6000", "side": "debit", "money": { "amount": "300.00", "currency": "USD" } },
          { "account": "1200", "side": "credit", "money": { "amount": "300.00", "currency": "USD" } }
        ]
      },
      "expect": { "result": { "entry": { "sequenceNumber": 2 } } } }
  ],
  "projections": [
    {
      "name": "incomeStatement",
      "params": { "tenant": "$T1", "fiscalYear": 2026, "throughPeriod": 12, "mapping": "us-gaap-income-statement" },
      "expect": {
        "positions": [
          { "key": "1", "amount": "1000.00" },
          { "key": "3", "amount": "-300.00" }
        ],
        "netIncome": "700.00"
      }
    },
    {
      "name": "balanceSheet",
      "params": { "tenant": "$T1", "asOf": "2026-12-31", "mapping": "us-gaap-balance-sheet", "incomeMapping": "us-gaap-income-statement" },
      "expect": {
        "assetsTotal": "770.00",
        "liabilitiesAndEquityTotal": "770.00"
      }
    }
  ]
}
