{
  "fixture": "us-contra-revenue",
  "description": "US-Pack: contra-revenue netting. Sales returns (4200) and sales discounts (4300) are type revenue with a debit balance; in the income statement they sit in the Net Sales range (4000-4399) and reduce it. Sale 1,000 − return 200 − discount 50 = Net Sales 750.",
  "covers": ["F-CORE-015", "SF-10"],
  "setup": {},
  "steps": [
    { "op": "createTenant", "input": { "name": "Returns Corp", "baseCurrency": "USD", "pack": "us", "firstFiscalYear": 2026 },
      "expect": { "result": { "id": "$T1", "pack": { "id": "us", "version": "2026.1" } } } },
    { "op": "postVoucher", "input": {
        "tenant": "$T1", "voucher": { "voucherNumber": "INV-001", "voucherDate": "2026-03-01" },
        "entryDate": "2026-03-01", "text": "Cash sale 7%", "taxCode": "SALETAX", "direction": "output",
        "netLines": [ { "account": "4000", "money": { "amount": "1000.00", "currency": "USD" } } ], "counterAccount": "1010" },
      "expect": { "result": { "grossTotal": { "amount": "1070.00", "currency": "USD" } } } },
    { "op": "postVoucher", "input": {
        "tenant": "$T1", "voucher": { "voucherNumber": "CR-001", "voucherDate": "2026-03-10" },
        "entryDate": "2026-03-10", "text": "Customer return",
        "lines": [
          { "account": "4200", "side": "debit", "money": { "amount": "200.00", "currency": "USD" } },
          { "account": "1010", "side": "credit", "money": { "amount": "200.00", "currency": "USD" } }
        ] },
      "expect": { "result": { "entry": { "sequenceNumber": 2 } } } },
    { "op": "postVoucher", "input": {
        "tenant": "$T1", "voucher": { "voucherNumber": "CR-002", "voucherDate": "2026-03-20" },
        "entryDate": "2026-03-20", "text": "Early-payment discount",
        "lines": [
          { "account": "4300", "side": "debit", "money": { "amount": "50.00", "currency": "USD" } },
          { "account": "1010", "side": "credit", "money": { "amount": "50.00", "currency": "USD" } }
        ] },
      "expect": { "result": { "entry": { "sequenceNumber": 3 } } } }
  ],
  "projections": [
    { "name": "incomeStatement", "params": { "tenant": "$T1", "fiscalYear": 2026, "throughPeriod": 12, "mapping": "us-gaap-income-statement" },
      "expect": {
        "positions": [ { "key": "1", "amount": "750.00" } ],
        "netIncome": "750.00"
      } },
    { "name": "trialBalance", "params": { "tenant": "$T1", "fiscalYear": 2026, "throughPeriod": 12 },
      "expect": { "rows": [
        { "account": "1010", "balance": "820.00" },
        { "account": "2100", "balance": "-70.00" },
        { "account": "4000", "balance": "-1000.00" },
        { "account": "4200", "balance": "200.00" },
        { "account": "4300", "balance": "50.00" }
      ] } }
  ]
}
