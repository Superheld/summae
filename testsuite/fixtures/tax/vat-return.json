  "projections": [
    {
      "name": "vatReturn",
      "params": { "year": 2026, "quarter": 2, "asOf": "2026-07-01" },
      "expect": {
        "comment": "Soll-Versteuerung: Rechnung vom 10.04. zählt in Q2, obwohl unbezahlt",
