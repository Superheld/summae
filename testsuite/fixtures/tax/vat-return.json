    },
    {
      "name": "vatReturn",
      "params": { "year": 2026, "quarter": 1, "asOf": "2026-07-01" },
      "expect": { "comment": "Q1 leer", "keys": {}, "payload": { "amount": "0.00", "currency": "EUR" } }
