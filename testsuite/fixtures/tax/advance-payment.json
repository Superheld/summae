{
  "fixture": "advance-payment",
  "description": "SF-19 (Review M3): Anzahlung erhalten — USt bei Vereinnahmung (Mindest-Ist, auch für Soll-Versteuerer); Schlussrechnung mit Verrechnung; VA zeigt je Quartal nur den richtigen Anteil.",
  "covers": ["F-TAX-009", "SF-19"],
  "setup": {
    "tenant": { "name": "Fixture GmbH", "baseCurrency": "EUR", "taxProfile": { "taxationMethod": "accrual" } },
    "accounts": [
      { "number": "1200", "name": "Bank", "type": "asset", "subtype": "bank" },
      { "number": "1400", "name": "Forderungen", "type": "asset", "subtype": "ar" },
      { "number": "3272", "name": "Erhaltene Anzahlungen 19%", "type": "liability" },
      { "number": "8400", "name": "Erlöse 19%", "type": "revenue" },
      { "number": "1776", "name": "USt 19%", "type": "liability", "subtype": "tax_out" }
    ],
    "fiscalYears": [ { "year": 2026, "start": "2026-01-01", "end": "2026-12-31" } ],
    "vouchers": [
      { "id": "$V1", "voucherNumber": "ANZ-1", "voucherDate": "2026-02-10" },
      { "id": "$V2", "voucherNumber": "SR-1", "voucherDate": "2026-05-20" }
    ],
    "taxCodes": [
      { "code": "USt19", "versions": [ { "validFrom": "2024-01-01", "validTo": null, "rate": "19.00", "taxAccount": "1776", "reportingKey": "81" } ] }
    ]
  },
  "steps": [
    {
      "op": "post",
      "input": {
        "entryDate": "2026-02-10", "voucherId": "$V1", "text": "Anzahlung erhalten (50%)",
        "lines": [
          { "account": "1200", "side": "debit", "money": { "amount": "595.00", "currency": "EUR" } },
          { "account": "3272", "side": "credit", "money": { "amount": "500.00", "currency": "EUR" },
            "taxTag": { "code": "USt19", "appliedVersion": "2024-01-01", "reportingKey": "81", "baseMoney": { "amount": "500.00", "currency": "EUR" } } },
          { "account": "1776", "side": "credit", "money": { "amount": "95.00", "currency": "EUR" },
            "taxTag": { "code": "USt19", "appliedVersion": "2024-01-01", "reportingKey": "81", "baseMoney": { "amount": "500.00", "currency": "EUR" } } }
        ]
      },
      "expect": { "result": { "sequenceNumber": 1 } }
    },
    {
      "op": "post",
      "input": {
        "entryDate": "2026-05-20", "voucherId": "$V2", "text": "Schlussrechnung 1.190 brutto",
        "lines": [
          { "account": "1400", "side": "debit", "money": { "amount": "1190.00", "currency": "EUR" } },
          { "account": "8400", "side": "credit", "money": { "amount": "1000.00", "currency": "EUR" },
            "taxTag": { "code": "USt19", "appliedVersion": "2024-01-01", "reportingKey": "81", "baseMoney": { "amount": "1000.00", "currency": "EUR" } } },
          { "account": "1776", "side": "credit", "money": { "amount": "190.00", "currency": "EUR" },
            "taxTag": { "code": "USt19", "appliedVersion": "2024-01-01", "reportingKey": "81", "baseMoney": { "amount": "1000.00", "currency": "EUR" } } }
        ]
      },
      "expect": { "result": { "sequenceNumber": 2, "openItemsCreated": [ { "id": "$OP1", "money": { "amount": "1190.00", "currency": "EUR" } } ] } }
    },
    {
      "op": "post",
      "input": {
        "entryDate": "2026-05-20", "voucherId": "$V2", "text": "Verrechnung Anzahlung mit Schlussrechnung",
        "lines": [
          { "account": "3272", "side": "debit", "money": { "amount": "500.00", "currency": "EUR" },
            "taxTag": { "code": "USt19", "appliedVersion": "2024-01-01", "reportingKey": "81", "baseMoney": { "amount": "-500.00", "currency": "EUR" } } },
          { "account": "1776", "side": "debit", "money": { "amount": "95.00", "currency": "EUR" },
            "taxTag": { "code": "USt19", "appliedVersion": "2024-01-01", "reportingKey": "81", "baseMoney": { "amount": "-500.00", "currency": "EUR" } } },
          { "account": "1400", "side": "credit", "money": { "amount": "595.00", "currency": "EUR" } }
        ]
      },
      "expect": { "result": { "sequenceNumber": 3, "id": "$E3" } }
    },
    {
      "op": "settle",
      "input": { "entryId": "$E3", "allocations": [ { "openItemId": "$OP1", "money": { "amount": "595.00", "currency": "EUR" } } ] },
      "expect": { "result": { "openItems": [ { "id": "$OP1", "remaining": { "amount": "595.00", "currency": "EUR" }, "status": "partially_settled" } ] } }
    }
  ],
  "projections": [
    {
      "name": "vatReturn",
      "params": { "year": 2026, "quarter": 1, "asOf": "2026-07-01" },
      "expect": {
        "comment": "Mindest-Ist: USt entsteht mit Vereinnahmung der Anzahlung",
        "keys": { "81": { "base": "500.00", "tax": "95.00" } }
      }
    },
    {
      "name": "vatReturn",
      "params": { "year": 2026, "quarter": 2, "asOf": "2026-07-01" },
      "expect": {
        "comment": "Schlussrechnung 1000/190 abzüglich Verrechnung 500/95 → nur der Rest",
        "keys": { "81": { "base": "500.00", "tax": "95.00" } }
      }
    }
  ]
}
