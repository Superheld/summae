{
  "fixture": "tax-expansion",
  "description": "SF-02/03: Steuerexpansion side-effect-free; Rundung pro Beleg (nicht pro Position); kaufmännische Rundung (half-up, nicht half-even); Versionswahl nach Belegdatum.",
  "covers": ["F-TAX-001", "F-TAX-002", "SF-02", "SF-03"],
  "setup": {
    "tenant": { "name": "Fixture GmbH", "baseCurrency": "EUR" },
    "accounts": [
      { "number": "1200", "name": "Bank", "type": "asset", "subtype": "bank" },
      { "number": "8400", "name": "Erlöse 19%", "type": "revenue" },
      { "number": "8300", "name": "Erlöse 7%", "type": "revenue" },
      { "number": "1776", "name": "USt 19%", "type": "liability", "subtype": "tax_out" },
      { "number": "1771", "name": "USt 7%", "type": "liability", "subtype": "tax_out" }
    ],
    "fiscalYears": [ { "year": 2026, "start": "2026-01-01", "end": "2026-12-31" } ],
    "vouchers": [],
    "taxCodes": [
      {
        "code": "USt19",
        "versions": [ { "validFrom": "2024-01-01", "validTo": null, "rate": "19.00", "taxAccount": "1776", "reportingKey": "81" } ]
      },
      {
        "code": "USt7",
        "versions": [ { "validFrom": "2024-01-01", "validTo": null, "rate": "7.00", "taxAccount": "1771", "reportingKey": "86" } ]
      }
    ]
  },
  "steps": [
    {
      "op": "expandTax",
      "input": {
        "date": "2026-05-10", "taxCode": "USt19", "direction": "output",
        "netLines": [
          { "account": "8400", "money": { "amount": "0.33", "currency": "EUR" } },
          { "account": "8400", "money": { "amount": "0.33", "currency": "EUR" } },
          { "account": "8400", "money": { "amount": "0.33", "currency": "EUR" } }
        ]
      },
      "expect": {
        "result": {
          "comment": "Pro Beleg: 0.99 × 19% = 0.1881 → 0.19. Positionsweise wäre fälschlich 0.18.",
          "taxLines": [ { "account": "1776", "side": "credit", "money": { "amount": "0.19", "currency": "EUR" }, "taxTag": { "code": "USt19", "reportingKey": "81" } } ],
          "grossTotal": { "amount": "1.18", "currency": "EUR" }
        }
      }
    },
    {
      "op": "expandTax",
      "input": {
        "date": "2026-05-10", "taxCode": "USt7", "direction": "output",
        "netLines": [ { "account": "8300", "money": { "amount": "17.50", "currency": "EUR" } } ]
      },
      "expect": {
        "result": {
          "comment": "17.50 × 7% = 1.225 → half-up 1.23 (half-even ergäbe fälschlich 1.22 — determinismus.md §2)",
          "taxLines": [ { "account": "1771", "side": "credit", "money": { "amount": "1.23", "currency": "EUR" } } ],
          "grossTotal": { "amount": "18.73", "currency": "EUR" }
        }
      }
    },
    {
      "op": "expandTax",
      "input": {
        "date": "2026-05-10", "taxCode": "Fantasie", "direction": "output",
        "netLines": [ { "account": "8400", "money": { "amount": "100.00", "currency": "EUR" } } ]
      },
      "expect": { "error": "E_TAXCODE_UNKNOWN" }
    },
    {
      "op": "expandTax",
      "input": {
        "date": "2020-01-01", "taxCode": "USt19", "direction": "output",
        "netLines": [ { "account": "8400", "money": { "amount": "100.00", "currency": "EUR" } } ]
      },
      "expect": { "error": "E_TAXCODE_NO_VALID_VERSION", "comment": "Belegdatum vor validFrom der einzigen Version" }
    }
  ],
  "projections": []
}
